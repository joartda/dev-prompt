## 공통 코루틴 패턴
```kotlin
// 병렬 분해
suspend fun loadAll(): Triple<A, B, C> = coroutineScope {
    val a = async { loadA() }
    val b = async { loadB() }
    val c = async { loadC() }
    Triple(a.await(), b.await(), c.await())
}

// 타임아웃
suspend fun fetchWithTimeout(url: String): String = withTimeout(5000) {
    httpClient.get(url).body()
}

// Flow 스트리밍
fun userUpdates(): Flow<User> = flow {
    while (true) {
        emit(repository.pollForUpdate())
        delay(1000)
    }
}

// 구조적 동시성
suspend fun processBatch(items: List<Item>) = coroutineScope {
    items.map { item ->
        async(Dispatchers.IO) { process(item) }
    }.awaitAll()
}
```

